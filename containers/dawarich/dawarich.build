# vim: ft=systemd

[Unit]
Description=Build unit for Dawarich container patches

[Service]
EnvironmentFile=%E/containers/systemd/dawarich/dawarich.env

[Build]
SetWorkingDirectory=%E/containers/systemd/dawarich
File=Containerfile.dawarich-patch
PodmanArgs=--build-arg=dawarich_tag=${DAWARICH_TAG}
ImageTag=dawarich-patched:${DAWARICH_TAG}
